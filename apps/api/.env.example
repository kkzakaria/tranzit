# Local dev (peer auth via Unix socket)
DATABASE_URL=postgresql://superz@localhost/tranzit_dev?host=/var/run/postgresql
# Production (TCP with password)
# DATABASE_URL=postgresql://user:password@localhost:5432/tranzit_dev
S3_ENDPOINT=http://localhost:9010
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=tranzit
WEB_URL=http://localhost:34000
PORT=34001
BETTER_AUTH_SECRET=change-me-in-production-min-32-chars
BETTER_AUTH_URL=http://localhost:34001
